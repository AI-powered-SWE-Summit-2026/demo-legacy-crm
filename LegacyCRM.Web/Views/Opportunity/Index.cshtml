@model IEnumerable<LegacyCRM.Core.Models.Opportunity>
@using System.Collections.Generic
@{
    ViewBag.Title = "Opportunities";
    var summary = ViewBag.StageSummary as IDictionary<string, int>;
}
<div class="page-header clearfix">
    <h2 class="pull-left">Opportunity Pipeline</h2>
    <div class="pull-right">@Html.ActionLink("Create Opportunity", "Create", null, new { @class = "btn btn-primary" })</div>
</div>
<div class="row">
    @if (summary != null)
    {
        foreach (var item in summary)
        {
            <div class="col-md-2">
                <div class="panel panel-default">
                    <div class="panel-heading">@item.Key</div>
                    <div class="panel-body"><strong>@item.Value</strong></div>
                </div>
            </div>
        }
    }
</div>
<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Customer</th>
            <th>Title</th>
            <th>Stage</th>
            <th>Value</th>
            <th>Expected Close</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@(item.Customer != null ? item.Customer.CompanyName : "-")</td>
            <td>@item.Title</td>
            <td>@item.Stage</td>
            <td>@item.Value.ToString("C")</td>
            <td>@item.ExpectedCloseDate.ToString("yyyy-MM-dd")</td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { id = item.Id }, new { @class = "btn btn-xs btn-primary" })
                @using (Html.BeginForm("Delete", "Opportunity", new { id = item.Id }, FormMethod.Post, new { @class = "inline-form" }))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-xs btn-danger" onclick="return confirm('Delete this opportunity?');">Delete</button>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
