@model IEnumerable<LegacyCRM.Core.Models.Ticket>
@{
    ViewBag.Title = "Tickets";
}
<div class="page-header clearfix">
    <h2 class="pull-left">Support Tickets</h2>
    <div class="pull-right">@Html.ActionLink("Create Ticket", "Create", null, new { @class = "btn btn-primary" })</div>
</div>
@using (Html.BeginForm("Index", "Ticket", FormMethod.Get, new { @class = "form-inline filter-bar" }))
{
    <div class="form-group">@Html.DropDownList("status", (IEnumerable<SelectListItem>)ViewBag.Status, "All statuses", new { @class = "form-control" })</div>
    <button type="submit" class="btn btn-default">Filter</button>
}
<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Customer</th>
            <th>Title</th>
            <th>Priority</th>
            <th>Status</th>
            <th>Assigned</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@(item.Customer != null ? item.Customer.CompanyName : "-")</td>
            <td>@item.Title</td>
            <td>@item.Priority</td>
            <td>@item.Status</td>
            <td>@(item.AssignedUser != null ? item.AssignedUser.FullName : "-")</td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { id = item.Id }, new { @class = "btn btn-xs btn-primary" })
                @using (Html.BeginForm("Delete", "Ticket", new { id = item.Id }, FormMethod.Post, new { @class = "inline-form" }))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-xs btn-danger" onclick="return confirm('Delete this ticket?');">Delete</button>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
