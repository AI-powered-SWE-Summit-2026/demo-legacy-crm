@model LegacyCRM.Web.Models.ViewModels.DashboardViewModel
@using System.Web.Helpers
@{
    ViewBag.Title = "Dashboard";
    var grid = new WebGrid(Model.RecentCustomers, canPage: false, canSort: false);
}
<div class="jumbotron">
    <h1>@Model.WelcomeMessage</h1>
    <p>Legacy CRM dashboard powered by MVC 5, EF6, and classic System.Web components.</p>
    <p><small>ObjectContext timeout: @ViewBag.CommandTimeout minutes</small></p>
</div>
<div class="row stat-row">
    <div class="col-md-4">
        <div class="panel panel-primary"><div class="panel-body"><h3>@Model.TotalCustomers</h3><p>Total customers</p></div></div>
    </div>
    <div class="col-md-4">
        <div class="panel panel-success"><div class="panel-body"><h3>@Model.OpenOpportunities</h3><p>Open opportunities</p></div></div>
    </div>
    <div class="col-md-4">
        <div class="panel panel-danger"><div class="panel-body"><h3>@Model.OpenTickets</h3><p>Open tickets</p></div></div>
    </div>
</div>
<div class="row">
    <div class="col-md-8">
        <h3>Recent customers</h3>
        @grid.GetHtml(
            tableStyle: "table table-striped table-bordered",
            columns: grid.Columns(
                grid.Column("CompanyName", "Company"),
                grid.Column("Name", "Primary Contact"),
                grid.Column("Status"),
                grid.Column("Country")
            ))
    </div>
    <div class="col-md-4">
        <h3>Pipeline summary</h3>
        <ul class="list-group">
            @foreach (var stage in Model.PipelineSummary)
            {
                <li class="list-group-item"><span class="badge">@stage.Value.ToString("C0")</span>@stage.Key</li>
            }
        </ul>
    </div>
</div>
<div class="row">
    <div class="col-md-12">
        <h3>Recent tickets</h3>
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Customer</th>
                    <th>Title</th>
                    <th>Status</th>
                    <th>Created</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var ticket in Model.RecentTickets)
            {
                <tr>
                    <td>@(ticket.Customer != null ? ticket.Customer.CompanyName : "-")</td>
                    <td>@ticket.Title</td>
                    <td>@ticket.Status</td>
                    <td>@ticket.CreatedAt.ToString("yyyy-MM-dd")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
