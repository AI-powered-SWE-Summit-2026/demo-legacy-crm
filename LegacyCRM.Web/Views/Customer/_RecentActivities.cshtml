@model IEnumerable<LegacyCRM.Core.Models.Activity>
<h4>Recent Activities</h4>
<table class="table table-condensed table-bordered">
    <thead>
        <tr>
            <th>Date</th>
            <th>Type</th>
            <th>Description</th>
            <th>By</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var activity in Model)
    {
        <tr>
            <td>@activity.ActivityDate.ToString("yyyy-MM-dd HH:mm")</td>
            <td>@activity.Type</td>
            <td>@activity.Description</td>
            <td>@(activity.CreatedByUser != null ? activity.CreatedByUser.FullName : "-")</td>
        </tr>
    }
    </tbody>
</table>
